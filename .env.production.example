###############################################################################
# Production .env template for nusagrade.com on Hostinger.
#
# You do NOT need to fill this manually. The web installer handles everything:
#   1. Upload the project files to Hostinger
#   2. Open https://nusagrade.com/install.php in your browser
#   3. Fill in 3-4 fields (DB password, mail password, admin credentials)
#   4. Click Install — done.
#
# This file is used by install.php as a template. Only commit it without
# secrets. Never commit the real .env to Git.
###############################################################################

APP_NAME=Nusagrade
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://nusagrade.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ---------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database (Hostinger MySQL) -------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u404974420_nusagrade
DB_USERNAME=u404974420_nusagradedb
DB_PASSWORD=

# --- Session / cache / queue ---------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Mail (Hostinger Email for contact@nusagrade.com) --------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=contact@nusagrade.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="contact@nusagrade.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS / S3 (unused, leave blank) --------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Admin user (seeded on install) --------------------------------------
# install.php asks for these. After login, change password from admin UI.
ADMIN_NAME=Duncan
ADMIN_EMAIL=contact@nusagrade.com
ADMIN_PASSWORD=
